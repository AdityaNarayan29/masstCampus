# ============ PRODUCTION ENV TEMPLATE ============
# Copy this to .env on your production server (Render)

# Database (Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/school_crm?sslmode=require

# Auth
JWT_SECRET=generate-a-64-char-random-string-here
JWT_EXPIRES_IN=7d

# Server
NODE_ENV=production
PORT=3001

# CORS (your Vercel domain)
CORS_ALLOWED_ORIGINS=https://masstcampus.in,https://www.masstcampus.in,https://masst-campus.vercel.app

# Clerk (optional - leave empty to disable)
ENABLE_CLERK_AUTH=false
CLERK_WEBHOOK_SECRET=
